# =============================================================================
# ConciergeOS — Variables d'environnement
# Copier ce fichier en .env.local et renseigner les valeurs
# Ne JAMAIS committer .env.local ou tout fichier contenant de vrais secrets
# =============================================================================

# -------------------------------------------------------
# BASE DE DONNÉES
# -------------------------------------------------------
# MVP local : SQLite (chemin relatif, créé automatiquement)
DATABASE_URL=./data.db

# Production Supabase PostgreSQL :
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# -------------------------------------------------------
# AUTHENTIFICATION (Supabase Auth — production)
# -------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # JAMAIS exposé côté client

# JWT secret (générer avec: openssl rand -base64 64)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# -------------------------------------------------------
# PAIEMENTS (Stripe)
# -------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...         # Clé secrète (backend uniquement)
STRIPE_WEBHOOK_SECRET=whsec_...       # Secret du webhook endpoint
VITE_STRIPE_PUBLIC_KEY=pk_test_...    # Clé publique (frontend)

# -------------------------------------------------------
# EMAILS (Resend)
# -------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@votre-domaine.fr

# -------------------------------------------------------
# SMS (Twilio)
# -------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+33...

# -------------------------------------------------------
# JOBS ASYNCHRONES (Inngest)
# -------------------------------------------------------
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-...

# -------------------------------------------------------
# MONITORING (Sentry)
# -------------------------------------------------------
SENTRY_DSN=https://...@sentry.io/...
VITE_SENTRY_DSN=https://...@sentry.io/...  # Frontend

# -------------------------------------------------------
# STOCKAGE FICHIERS (Supabase Storage)
# -------------------------------------------------------
STORAGE_BUCKET=conciergeos-media

# -------------------------------------------------------
# APPLICATION
# -------------------------------------------------------
NODE_ENV=development           # development | production
PORT=5000                      # Port du serveur Express
APP_URL=http://localhost:5000  # URL publique de l'app (sans slash final)

# -------------------------------------------------------
# CHANNEL MANAGER (optionnel — Phase 2)
# -------------------------------------------------------
# SMOOBU_API_KEY=...
# BOOKING_COM_API_KEY=...

# -------------------------------------------------------
# SERRURES CONNECTÉES (optionnel — Phase 2)
# -------------------------------------------------------
# NUKI_API_KEY=...
# IGLOOHOME_API_KEY=...
